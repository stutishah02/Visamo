@model WebApplication3.Models.Service

@{
    ViewData["Title"] = "Edit Service";
    Layout = "~/Views/Shared/resident.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white text-center">
                    <h3 class="mb-0">Edit Service</h3>
                </div>
                <div class="card-body">
                    <form asp-action="ServiceEdit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Sid" />
                        <div class="mb-3">
                            <label asp-for="Flatno" class="form-label"></label>
                            <input asp-for="Flatno" class="form-control" type="text" />
                            <span asp-validation-for="Flatno" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Wingno" class="form-label"></label>
                            <input asp-for="Wingno" class="form-control" type="text" />
                            <span asp-validation-for="Wingno" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label"></label>
                            <input asp-for="Description" class="form-control" />
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Typeofservice" class="form-label"></label>
                            <input asp-for="Typeofservice" class="form-control" />
                            <span asp-validation-for="Typeofservice" class="text-danger"></span>
                        </div>



                       @*  <div class="mb-3">
                            <label asp-for="Completedatetime" class="form-label"></label>
                            <input asp-for="Completedatetime" class="form-control" type="datetime-local" />
                            <span asp-validation-for="Completedatetime" class="text-danger"></span>
                        </div> *@

                       @*  <div class="mb-3">
                            <label asp-for="Nameofworker" class="form-label"></label>
                            <input asp-for="Nameofworker" class="form-control" />
                            <span asp-validation-for="Nameofworker" class="text-danger"></span>
                        </div> *@

                       

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <button type="submit" class="btn btn-primary">Save</button>
                           @*  <a asp-action="Index" class="btn btn-secondary">Back to List</a> *@
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
<style>
    body {
        background-color: #f8f9fa;
    }

    .card {
        border-radius: 10px;
        overflow: hidden;
    }

    .card-header {
        font-size: 1.5rem;
        font-weight: bold;
    }

    .form-floating label {
        color: #6c757d;
    }

    .form-floating input:focus,
    .form-floating select:focus {
        border-color: #17a2b8;
        box-shadow: 0 0 5px rgba(23, 162, 184, 0.5);
    }

    .btn-info {
        background-color: rgb(0, 133, 219);
        border: none;
    }

        .btn-info:hover {
            background-color: #138496;
        }

    .btn-outline-secondary {
        color: #6c757d;
        border-color: #6c757d;
    }

        .btn-outline-secondary:hover {
            color: white;
            background-color: #6c757d;
        }
</style>