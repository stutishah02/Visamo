@model IEnumerable<WebApplication3.Models.Visitor>

@{
    ViewData["Title"] = "VisitorView";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="card">
        <div class="card-body">
            <div class="mb-4 pb-2 d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Visitor List</h5>
            </div>

            <!-- Wing Filter Buttons -->
            <div class="d-flex justify-content-center gap-2 mb-3">
                <button class="btn btn-outline-primary filter-btn" data-wing="A">Wing A</button>
                <button class="btn btn-outline-secondary filter-btn" data-wing="B">Wing B</button>
                <button class="btn btn-outline-success filter-btn" data-wing="C">Wing C</button>
                <button class="btn btn-outline-danger filter-btn" data-wing="D">Wing D</button>
                <button class="btn btn-dark filter-btn" data-wing="all">Show All</button>
            </div>

            <div class="table-responsive pb-4">
                <table id="all-student" class="table table-striped table-bordered border text-nowrap align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Wing No - Flat No</th>
                            <th>@Html.DisplayNameFor(model => model.Vname)</th>
                            <th>@Html.DisplayNameFor(model => model.Numberofvisitor)</th>
                            <th>@Html.DisplayNameFor(model => model.Type)</th>
                            <th>@Html.DisplayNameFor(model => model.Datetime)</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr data-wing="@item.Wingno">
                                <td>@Html.DisplayFor(modelItem => item.Wingno)-@Html.DisplayFor(modelItem => item.Flatno)</td>
                                <td>@Html.DisplayFor(modelItem => item.Vname)</td>
                                <td>@Html.DisplayFor(modelItem => item.Numberofvisitor)</td>
                                <td>@Html.DisplayFor(modelItem => item.Type)</td>
                                <td> @item.Datetime.ToString("dd-MM-yyyy")</td>

                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    /* Keep old table design */
    table {
        border-collapse: collapse;
        width: 100%;
    }

    .table thead th {
        text-transform: uppercase;
        text-align: left;
    }

    .table td,
    .table th {
        text-align: left;
        vertical-align: middle;
    }

    .btn {
        text-transform: uppercase;
        font-size: 0.875rem;
    }

    /* New Wing Filter Button Styling */
    .filter-btn {
        padding: 10px 20px;
        font-weight: bold;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const buttons = document.querySelectorAll(".filter-btn");
        const rows = document.querySelectorAll("#all-student tbody tr");

        buttons.forEach(button => {
            button.addEventListener("click", function () {
                const wing = this.getAttribute("data-wing");

                rows.forEach(row => {
                    if (wing === "all" || row.getAttribute("data-wing") === wing) {
                        row.style.display = "";
                    } else {
                        row.style.display = "none";
                    }
                });
            });
        });
    });
</script>
