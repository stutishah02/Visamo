@model IEnumerable<WebApplication3.Models.Event>

@{
    ViewData["Title"] = "View Event";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">

    <div class="card">
        <div class="card-body">
            <div class="mb-4 pb-2 align-items-center">
                <h5 class="mb-0">Event List</h5><br />
               @*  <a asp-action="Create" class="btn btn-primary">Create New Event</a> *@
            </div>
            <div class="table-responsive pb-4">
                <table id="all-student" class="table table-striped table-bordered border text-nowrap align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.Eventname)</th>
                            <th>@Html.DisplayNameFor(model => model.Ndays)</th>
                            <th>@Html.DisplayNameFor(model => model.Amount)</th>
                            <th>@Html.DisplayNameFor(model => model.Reqdate)</th>
                            <th>@Html.DisplayNameFor(model => model.Bookdate)</th>


                            @* <th>Actions</th> *@
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@Html.DisplayFor(modelItem => item.Eventname)</td>
                                <td>@Html.DisplayFor(modelItem => item.Ndays)</td>
                                <td>
                                    ₹ @Html.DisplayFor(modelItem => item.Amount)
                                </td>
                                <td>
                                    @item.Reqdate.ToString("dd-MM-yyyy")
                                </td>
                                <td>
                                    @item.Bookdate.ToString("dd-MM-yyyy")
                                </td>



                               @*  <td>
                                    <a asp-action="EventEdit" asp-route-id="@item.Eid" class="text-primary">
                                        <i class="ti ti-pencil fs-7"></i>
                                    </a>

                                    <a asp-action="DeleteEvent" asp-route-id="@item.Eid" onclick="return confirm('Are you sure you want to delete this user?')" class="text-danger ms-2">
                                        <i class="ti ti-trash fs-7"></i>
                                    </a>
                                </td> *@
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    /* Enhance table design */
    table {
        border-collapse: collapse;
        width: 100%;
    }

    .table thead th {
        text-transform: uppercase;
        text-align: left;
    }

    .table td,
    .table th {
        text-align: left;
        vertical-align: middle;
    }

    .btn {
        text-transform: uppercase;
        font-size: 0.875rem;
    }

    .container h1 {
        color: #333;
    }
</style>
